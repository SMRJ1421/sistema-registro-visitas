        <div class="card-body">
            <p class="text-muted">Ingrese su correo electrónico y le enviaremos su nombre de usuario registrado.</p>
            <form id="formRecoverUser">
                <div class="mb-3">
                    <label for="emailUser" class="form-label">Correo electrónico</label>
                    <input type="email" id="emailUser" class="form-control" autocomplete="email" required placeholder="usuario@dominio.com">
                </div>
                <button type="submit" class="btn btn-danger">Enviar</button>
                <a href="login.html" class="btn btn-link">Volver al inicio</a>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const URL_RECOVER_USER = 'http://127.0.0.1:8080/api/auth/recover-username';

        $(document).ready(function(){
            $('#formRecoverUser').on('submit', function(e){
                e.preventDefault();
                const email = $('#emailUser').val().trim();
                if (!email) return;

                $.ajax({
                    url: URL_RECOVER_USER,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: email }),
                    success: function(resp){
                        // Esperamos que el backend responda con { username: '...' }
                        if (resp && resp.username) {
                            Swal.fire('Usuario enviado', `Se envió su usuario: <strong>${resp.username}</strong> a su correo.`, 'success');
                        } else {
                            Swal.fire('Enviado', 'Si la dirección existe en el sistema, recibirá un correo con su usuario.', 'info');
                        }
                    },
                    error: function(){
                        Swal.fire('Error', 'No fue posible procesar la solicitud. Contacte con soporte.', 'error');
                    }
                });
            });
        });
    </script>
