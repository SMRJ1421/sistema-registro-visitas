<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recuperar Contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link rel="stylesheet" href="css/estilos.css">
    <style>
        body { background:#f8f9fa; }
        .card { max-width:720px; margin:40px auto; }
    </style>
</head>
<body>
    <div class="card shadow-sm animate__animated animate__fadeInUp">
        <div class="card-header bg-danger text-white fw-bold">Recuperar Contraseña</div>
        <div class="card-body">
            <p class="text-muted">Ingrese su correo electrónico para enviar un código de verificación. Luego podrá establecer una nueva contraseña.</p>
            <form id="formRecoverPass">
                <div class="mb-3">
                    <label for="email" class="form-label">Correo electrónico</label>
                    <input type="email" id="email" class="form-control" autocomplete="email" required placeholder="usuario@dominio.com">
                </div>
                <button type="submit" class="btn btn-danger">Enviar código por correo</button>
                <a href="login.html" class="btn btn-link">Volver al inicio</a>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const URL_RECOVER_PASS = 'http://127.0.0.1:8080/api/auth/recover-password';

        $(document).ready(function(){
            $('#formRecoverPass').on('submit', function(e){
                e.preventDefault();
                const email = $('#email').val().trim();
                if (!email) return;

                $.ajax({
                    url: URL_RECOVER_PASS,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: email }),
                    success: function(resp){
                        Swal.fire('Código enviado', 'Revisa tu correo y pega el código en la siguiente pantalla.', 'success').then(()=>{
                            Swal.fire({
                                title: 'Código de verificación',
                                input: 'text',
                                inputLabel: 'Ingresa el código que recibiste por correo',
                                showCancelButton: true
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    const code = result.value;
                                    // Simular verificación o llamar a API de verificación
                                    $.ajax({
                                        url: `${URL_RECOVER_PASS}/verify`,
                                        type: 'POST',
                                        contentType: 'application/json',
                                        data: JSON.stringify({ email: email, code: code }),
                                        success: function(r){
                                            Swal.fire('Verificado', 'Ahora ingresa la nueva contraseña.', 'success').then(()=>{
                                                Swal.fire({
                                                    title: 'Nueva contraseña',
                                                    html: `<input id="newPass" type="password" class="swal2-input" placeholder="Nueva contraseña">`,
                                                    preConfirm: () => { return { password: $('#newPass').val() }; }
                                                }).then((resPass) => {
                                                    if (resPass.value && resPass.value.password) {
                                                        $.ajax({
                                                            url: `${URL_RECOVER_PASS}/reset`,
                                                            type: 'POST',
                                                            contentType: 'application/json',
                                                            data: JSON.stringify({ email: email, code: code, password: resPass.value.password }),
                                                            success: function() { Swal.fire('Contraseña actualizada', 'Ya puede iniciar sesión con su nueva contraseña.', 'success'); },
                                                            error: function(){ Swal.fire('Error', 'No se pudo actualizar la contraseña.', 'error'); }
                                                        });
                                                    }
                                                });
                                            });
                                        },
                                        error: function(){ Swal.fire('Error', 'Código inválido o expirado.', 'error'); }
                                    });
                                }
                            });
                        });
                    },
                    error: function(){
                        Swal.fire('Error', 'No fue posible enviar el código. Contacte con soporte.', 'error');
                    }
                });
            });
        });
    </script>
</body>
</html>
</file>

